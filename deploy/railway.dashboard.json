{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/dashboard.Dockerfile",
    "watchPatterns": [
      "apps/dashboard/**",
      "deploy/dashboard.Dockerfile",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "scripts/migrate-postgres.mjs"
    ]
  },
  "deploy": {
    "preDeployCommand": ["pnpm migrate:postgres"],
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS"
  }
}
