POSTGRES_DB=open_realtime
POSTGRES_USER=open_realtime
POSTGRES_PASSWORD=replace-with-strong-postgres-password

BETTER_AUTH_URL=https://realtime-admin.example.com
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
ORCHESTRATOR_APP_SECRET_KEY=replace-with-at-least-32-random-characters

OPEN_REALTIME_CLUSTER=mt1
OPEN_REALTIME_HOST=realtime.example.com

ORCHESTRATOR_URL=http://dashboard:3000
ORCHESTRATOR_TOKEN=replace-with-dashboard-created-token-that-has-ingest-write-and-registry-read
ORCHESTRATOR_TENANT_ID=tenant_from_dashboard
ORCHESTRATOR_APP_REGISTRY_REFRESH_MS=10000

OBSERVABILITY_DRIVER=axiom
OBSERVABILITY_ENVIRONMENT=production
AXIOM_TOKEN=replace-me
AXIOM_DATASET=open-realtime-events

DASHBOARD_PORT=3002
GATEWAY_PORT=3001
