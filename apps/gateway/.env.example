PUSHER_APP_ID=open-realtime
PUSHER_KEY=open-realtime-key
PUSHER_SECRET=replace-me
PUSHER_CLUSTER=mt1
PUSHER_TENANT_ID=self-hosted
PUSHER_APP_NAME="open realtime local"

# Optional shared-infra static app registry. If set, this replaces the single
# PUSHER_APP_ID/PUSHER_KEY/PUSHER_SECRET app above.
# PUSHER_APPS_JSON=[{"appId":"app1","key":"key1","secret":"secret1","tenantId":"tenant1","cluster":"mt1"}]

# Optional hosted registry mode. If true, the gateway pulls app credentials from
# ORCHESTRATOR_URL with ORCHESTRATOR_TOKEN instead of static PUSHER_* values.
ORCHESTRATOR_APP_REGISTRY=false
ORCHESTRATOR_APP_REGISTRY_REFRESH_MS=10000

PORT=3001

# Optional for local development. Required in production for cross-instance fanout,
# presence consistency, and durable at-least-once webhook delivery.
REDIS_URL=redis://default:password@host:6379
REDIS_PREFIX=open-realtime

# Optional comma-separated Pusher-style webhook delivery.
PUSHER_WEBHOOK_URLS=https://api.example.com/pusher/webhook
PUSHER_WEBHOOK_EVENTS=channel_occupied,channel_vacated,member_added,member_removed
PUSHER_WEBHOOK_BATCH_SIZE=100
PUSHER_WEBHOOK_FLUSH_INTERVAL_MS=1000

# Optional observability. Use "none", "console", or "axiom".
OBSERVABILITY_DRIVER=none
OBSERVABILITY_SERVICE=open-realtime
OBSERVABILITY_ENVIRONMENT=development
OBSERVABILITY_BATCH_SIZE=100
OBSERVABILITY_FLUSH_INTERVAL_MS=1000
OBSERVABILITY_MAX_QUEUE_SIZE=10000

# Required when OBSERVABILITY_DRIVER=axiom.
AXIOM_TOKEN=
AXIOM_DATASET=open-realtime-events
AXIOM_API_URL=https://api.axiom.co

# Optional product-state reporting to the dashboard/orchestrator.
# Bootstrap locally with: pnpm bootstrap:local
ORCHESTRATOR_URL=http://localhost:3002
ORCHESTRATOR_TOKEN=
ORCHESTRATOR_TENANT_ID=self-hosted
ORCHESTRATOR_FLUSH_INTERVAL_MS=5000
