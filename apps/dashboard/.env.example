BETTER_AUTH_URL=http://localhost:3002
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
ORCHESTRATOR_APP_SECRET_KEY=replace-with-at-least-32-random-characters
OPEN_REALTIME_SQLITE_PATH=/absolute/path/to/open-realtime/apps/dashboard/data/open-realtime.db
OPEN_REALTIME_TENANT_ID=self-hosted
OPEN_REALTIME_TENANT_NAME="Self Hosted"
OPEN_REALTIME_CLUSTER=self-host-1
OPEN_REALTIME_HOST=localhost:3001
ORCHESTRATOR_STORE_DRIVER=sqlite

# Hosted/SaaS only:
# ORCHESTRATOR_STORE_DRIVER=postgres
# POSTGRES_URL=postgres://user:password@host:5432/open_realtime
